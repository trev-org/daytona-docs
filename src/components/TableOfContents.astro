---
import { PAGE_TITLE_ID } from './TableOfContent/constants'
import TableOfContentsList from './TableOfContentsList.astro'

const { toc } = Astro.props
const overviewLabel =
  Astro.url.pathname.startsWith('/docs/jp') ||
  Astro.url.pathname.startsWith('/docs/ja')
    ? '概要'
    : 'Overview'
const overviewItem = {
  depth: 1,
  slug: PAGE_TITLE_ID,
  text: overviewLabel,
  children: [],
}
const tocItems = toc ? [overviewItem, ...toc.items] : []
---

{
  toc && (
    <starlight-toc
      data-min-h={toc.minHeadingLevel}
      data-max-h={toc.maxHeadingLevel}
    >
      <nav aria-labelledby="starlight__on-this-page">
        <h2 id="starlight__on-this-page" class="table-of-contents-title">
          # {Astro.locals.t('tableOfContents.title' as any)}
        </h2>
        <TableOfContentsList toc={tocItems} />
      </nav>
    </starlight-toc>
  )
}

<script src="./TableOfContent/starlight-toc"></script>

<style>
  starlight-toc {
    display: block;
  }

  .table-of-contents-title {
    font-family: 'Berkeley Mono', monospace;
    font-size: 0.75rem;
    font-weight: normal;
    line-height: 1;
    text-transform: uppercase;
    color: var(--primary-text-color);
    letter-spacing: -0.00875rem;
    padding-bottom: 10px;
    border-bottom: var(--border);
    width: 100%;
    margin: 0 0 0.5rem 0;
  }
</style>
