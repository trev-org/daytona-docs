---
import { getCollection } from 'astro:content'
import { resolveMintlifyPageData } from '../utils/mintlify-page-data'
import { getHeaderActiveState } from '../utils/navigation'
import { AssistantButton } from './Assistant'
import SidebarSublist from './SidebarSublist.astro'
import { SideNavLinks } from './menu/SideNavLinks'
import packageIcon from '@assets/sidebar/package.svg?raw'
import serverIcon from '@assets/sidebar/server.svg?raw'
import terminalIcon from '@assets/sidebar/terminal.svg?raw'

const PUBLIC_WEB_URL = (
  import.meta.env.PUBLIC_WEB_URL || 'https://daytona.io'
).replace(/\/$/, '')
const locale =
  Astro.props.lang === 'jp' || Astro.props.lang === 'ja'
    ? 'jp'
    : Astro.props.lang || 'en'
const {
  isTypescriptSdkActive,
  isPythonSdkActive,
  isRubySdkActive,
  isApiActive,
  isCliActive,
  isReferencesActive,
  isGuidesActive,
} = getHeaderActiveState(import.meta.env.BASE_URL, Astro.url.pathname)
const docs = await getCollection('docs')
const pageData = resolveMintlifyPageData(docs, Astro.url.pathname)
const showAssistant = !!import.meta.env.PUBLIC_MINTLIFY_ASSISTANT_KEY

function firstEntryHref(entry: any): string | undefined {
  if (entry.type === 'link') return entry.href
  for (const child of entry.entries || []) {
    const href = firstEntryHref(child)
    if (href) return href
  }
  return undefined
}

const referencePrefixes = [
  `${import.meta.env.BASE_URL}/${locale}/guides`,
  `${import.meta.env.BASE_URL}/${locale}/typescript-sdk`,
  `${import.meta.env.BASE_URL}/${locale}/python-sdk`,
  `${import.meta.env.BASE_URL}/${locale}/ruby-sdk`,
  `${import.meta.env.BASE_URL}/${locale}/go-sdk`,
  `${import.meta.env.BASE_URL}/${locale}/tools`,
]

function isReferenceOrGuideGroup(entry: any): boolean {
  if (entry.type !== 'group') return false
  const href = firstEntryHref(entry)
  return href
    ? referencePrefixes.some(prefix => href.startsWith(prefix))
    : false
}

const sidebarEntries = isReferencesActive || isGuidesActive
  ? pageData.sidebarEntries.filter(
      (entry: any) => entry.type !== 'group' || isReferenceOrGuideGroup(entry)
    )
  : pageData.sidebarEntries.filter(
      (entry: any) => entry.type !== 'group' || !isReferenceOrGuideGroup(entry)
    )
---

<Fragment>
  <SidebarSublist sublist={sidebarEntries} />
  <div class="navbar-links">
    <details class="mobile-dropdown" open={isReferencesActive}>
      <summary class:list={[{ active: isReferencesActive }]}>
        {Astro.locals.t('header.references' as any)}
        <svg
          class="chevron"
          width="10"
          height="6"
          viewBox="0 0 10 6"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M1 1L5 5L9 1"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </summary>
      <div class="mobile-dropdown-menu">
        <a
          href={`${import.meta.env.BASE_URL}/${locale}/typescript-sdk`}
          class:list={[{ active: isTypescriptSdkActive }]}
        >
          <Fragment set:html={packageIcon} />
          {Astro.locals.t('sidebarconfig.tsSdkReference' as any)}
        </a>
        <a
          href={`${import.meta.env.BASE_URL}/${locale}/python-sdk`}
          class:list={[{ active: isPythonSdkActive }]}
        >
          <Fragment set:html={packageIcon} />
          {Astro.locals.t('sidebarconfig.pythonSdkReference' as any)}
        </a>
        <a
          href={`${import.meta.env.BASE_URL}/${locale}/ruby-sdk`}
          class:list={[{ active: isRubySdkActive }]}
        >
          <Fragment set:html={packageIcon} />
          {Astro.locals.t('sidebarconfig.rubySdkReference' as any)}
        </a>
        <a
          href={`${import.meta.env.BASE_URL}/${locale}/tools/api`}
          class:list={[{ active: isApiActive }]}
        >
          <Fragment set:html={serverIcon} />
          {Astro.locals.t('sidebarconfig.apiReference' as any)}
        </a>
        <a
          href={`${import.meta.env.BASE_URL}/${locale}/tools/cli`}
          class:list={[{ active: isCliActive }]}
        >
          <Fragment set:html={terminalIcon} />
          {Astro.locals.t('sidebarconfig.cliReference' as any)}
        </a>
      </div>
    </details>
    <a
      href={`${import.meta.env.BASE_URL}/${locale}/guides`}
      class:list={[{ active: isGuidesActive }]}
    >
      {Astro.locals.t('header.guides' as any)}</a
    >
  </div>
  <div class="mobile-nav-btn nav__items_side_menu">
    {
      showAssistant && (
        <AssistantButton
          client:only="react"
          className="mobile-menu-assistant"
          buttonClassName="mobile-menu-assistant-button"
          showLabel
        />
      )
    }
    <SideNavLinks client:load locale={locale} />
  </div>

  <style>
  .navbar-links {
    display: none;
    align-items: flex-start;
    flex-direction: column;
    gap: 16px;
    border-top: 1px solid var(--border-color);
    padding-top: 20px;

    @media (max-width: 1024px) {
      display: flex;
    }
  }

  .navbar-links > a,
  .mobile-dropdown summary {
    text-transform: uppercase;
    font-size: 14px;
    font-family: 'Berkeley Mono', monospace;
    color: var(--primary-text-color);
    transition: all 0.2s;
    font-weight: 400;
    letter-spacing: -0.01rem;
    cursor: pointer;
    &:hover {
      color: var(--hover-color);
    }
    &.active {
      color: var(--hover-color);
    }
  }

  .mobile-dropdown {
    width: 100%;
  }

  .mobile-dropdown summary {
    display: flex;
    align-items: center;
    gap: 6px;
    list-style: none;
  }

  .mobile-dropdown summary::-webkit-details-marker {
    display: none;
  }

  .mobile-dropdown .chevron {
    width: 10px;
    height: 6px;
    transition: transform 0.2s;
  }

  .mobile-dropdown[open] .chevron {
    transform: rotate(180deg);
  }

  .mobile-dropdown-menu {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 12px 0 4px 0;
  }

  .mobile-dropdown-menu a {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    font-family: 'Berkeley Mono', monospace;
    color: var(--secondary-text-color);
    text-transform: none;
    transition: all 0.15s;
    &:hover {
      color: var(--hover-color);
    }
    &.active {
      color: var(--hover-color);
    }
  }

  .mobile-dropdown-menu a :global(svg) {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .mobile-dropdown-menu a :global(svg path) {
    fill: currentColor;
  }

  :global(.mobile-nav-btn .mobile-menu-assistant.assistant) {
    width: 100%;
    background: var(--block-bg-color);
    border-radius: 3px;
    transition: 0.6s;
  }

  :global(.mobile-nav-btn .mobile-menu-assistant.assistant .mobile-menu-assistant-button) {
    width: 100%;
    min-width: 0;
    height: auto;
    min-height: 30px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: 'Berkeley Mono', monospace;
    font-size: 0.875rem;
    line-height: 2.14;
    color: var(--primary-text-color);
    background: transparent;
    border: 0;
    text-transform: none;
    white-space: nowrap;
    box-sizing: border-box;
    cursor: pointer;
  }

  :global(.mobile-nav-btn .mobile-menu-assistant.assistant .mobile-menu-assistant-button span) {
    display: inline-block;
    white-space: nowrap;
  }

  :global(.mobile-nav-btn .mobile-menu-assistant.assistant:hover) {
    background: var(--secondary-text-color);
  }

  :global(.mobile-nav-btn .mobile-menu-assistant.assistant:hover .mobile-menu-assistant-button) {
    color: var(--white);
    cursor: pointer;
  }
  </style>
</Fragment>
