{
  "redirects": [
    {
      "source": "/",
      "destination": "/docs",
      "permanent": true
    },
    {
      "source": "/docs",
      "destination": "/docs/en",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/docs/:path*",
      "destination": "/:path*"
    }
  ]
}
